#!/usr/bin/env bash

set -o errexit
set -o xtrace

main() {
    if command -v pyenv >/dev/null 2>&1; then
        PYENV_PATH=$(command -v pyenv)
        echo "✅ Pyenv znaleziony w: $PYENV_PATH"
    else
        echo "❌ Pyenv nie jest zainstalowany lub nie znajduje się w \$PATH. Sprawdzam ręcznie..."
        
        if [ -d "$HOME/.pyenv" ]; then
            export PATH="$HOME/.pyenv/bin:$PATH"
            eval "$(pyenv init --path)"
            echo "✅ Pyenv znaleziony w \$HOME/.pyenv, dodano do \$PATH."
        elif [ -d "/opt/pyenv" ]; then
            export PATH="/opt/pyenv/bin:$PATH"
            eval "$(pyenv init --path)"
            echo "✅ Pyenv znaleziony w /opt/pyenv, dodano do \$PATH."
        else
            echo "❌ Pyenv nie został znaleziony. Upewnij się, że jest zainstalowany."
            exit 1
        fi
    fi

    PYENV_ROOT=$(pyenv root)
    if [ -d "$PYENV_ROOT" ]; then
        echo "✅ pyenv root: $PYENV_ROOT"
    else
        echo "❌ pyenv root ($PYENV_ROOT) nie istnieje. Sprawdź instalację pyenv."
        exit 1
    fi

    git config --global --add safe.directory "$PYENV_ROOT"

    cd "$PYENV_ROOT/bin/" || { echo "❌ Nie można przejść do katalogu pyenv!"; exit 1; }

    git checkout master

    if [ ! -d "$PYENV_ROOT/plugins/pyenv-update" ]; then
        git clone https://github.com/pyenv/pyenv-update.git "$PYENV_ROOT/plugins/pyenv-update"
        echo "✅ pyenv-update został zainstalowany."
    else
        echo "✅ pyenv-update już istnieje, pomijam klonowanie."
    fi

    pyenv update

    pyenv rehash && hash -r

    if pyenv --version >/dev/null 2>&1; then
        echo "✅ pyenv działa poprawnie po aktualizacji."
    else
        echo "❌ Błąd: pyenv nie działa po aktualizacji. Sprawdź ręcznie."
        exit 1
    fi
}

main "$@"
